{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nodegateway",
  "compatibility_date": "2026-04-05",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "nodegateway"
    }
  ]
}
