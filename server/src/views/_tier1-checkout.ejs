<!-- Tier 1: UPI QR Code + UTR Submission (step-based, compact) -->
<div id="tier1-payment" class="tier1-section">

  <!-- Step Tabs -->
  <div class="tier1-steps">
    <div class="tier1-step active" id="step1-tab" onclick="switchStep(1)">
      <div class="tier1-step-num">1</div>
      <span class="tier1-step-label">Scan & Pay</span>
    </div>
    <div class="tier1-step" id="step2-tab" onclick="switchStep(2)">
      <div class="tier1-step-num">2</div>
      <span class="tier1-step-label">Submit UTR</span>
    </div>
  </div>

  <!-- Step 1: QR + UPI Link -->
  <div class="tier1-panel active" id="step1-panel">
    <div class="qr-wrapper">
      <p class="qr-hint">Scan with any UPI app to pay</p>
      <div class="qr-frame">
        <img id="qr-image" src="" alt="UPI QR Code" />
      </div>
      <div class="qr-amount" id="pay-amount-display"></div>
    </div>

    <div class="qr-or-divider">or</div>

    <div style="text-align:center;">
      <a id="upi-link" href="#" class="upi-app-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
        Open UPI App
      </a>
    </div>

    <button type="button" class="next-step-btn" onclick="switchStep(2)">
      I've completed the payment &rarr;
    </button>
  </div>

  <!-- Step 2: UTR Submission -->
  <div class="tier1-panel" id="step2-panel">
    <div class="utr-panel-content" id="utr-form-area">
      <div class="utr-icon">&#9989;</div>
      <div class="utr-title">Confirm Your Payment</div>
      <div class="utr-subtitle">
        Enter the 12-digit UTR number from your<br>UPI app payment confirmation or bank SMS
      </div>

      <form id="utrForm">
        <div class="utr-input-wrapper">
          <input type="text" id="utr_number" name="utr_number" required
            pattern="[0-9]{12}" maxlength="12" minlength="12"
            inputmode="numeric"
            placeholder="000000000000" />
        </div>

        <button type="submit" class="pay-button" id="submitUtrBtn">Submit UTR</button>
      </form>

      <p class="utr-help">
        You'll find the UTR/Reference number in your payment app's<br>transaction details or in the SMS from your bank.
      </p>
    </div>

    <!-- Success state (shown after UTR submit) -->
    <div id="utr-success-area" style="display:none;">
      <div class="utr-success-card">
        <div class="icon">&#10004;</div>
        <div class="title">UTR Submitted Successfully</div>
        <div class="subtitle">The merchant will verify your payment shortly.<br>You can close this page now.</div>
      </div>
    </div>

    <div id="utr-message" class="message" style="display:none;"></div>
  </div>
</div>

<script>
  function switchStep(step) {
    document.getElementById('step1-tab').className = 'tier1-step' + (step === 1 ? ' active' : ' completed');
    document.getElementById('step2-tab').className = 'tier1-step' + (step === 2 ? ' active' : '');
    document.getElementById('step1-panel').className = 'tier1-panel' + (step === 1 ? ' active' : '');
    document.getElementById('step2-panel').className = 'tier1-panel' + (step === 2 ? ' active' : '');
  }

  function showTier1Payment(data) {
    document.getElementById('paymentForm').style.display = 'none';
    var tier1El = document.getElementById('tier1-payment');
    tier1El.classList.add('active');
    document.getElementById('qr-image').src = data.qr_image;
    document.getElementById('upi-link').href = data.upi_link;
    if (data.amount) {
      document.getElementById('pay-amount-display').innerHTML = '&#8377; ' + parseFloat(data.amount || 0).toFixed(2);
    }
    window.__orderId = data.order_id;
    window.__transactionId = data.transaction_id;
  }

  document.getElementById('utrForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    var btn = document.getElementById('submitUtrBtn');
    var msg = document.getElementById('utr-message');
    var utrVal = document.getElementById('utr_number').value.trim();

    if (!/^\d{12}$/.test(utrVal)) {
      msg.style.display = 'block';
      msg.className = 'message error';
      msg.textContent = 'Please enter a valid 12-digit UTR number.';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Submitting...';

    try {
      var res = await fetch('<%= baseUrl %>/api/payment/submit-utr', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          order_id: window.__orderId,
          utr_number: utrVal,
        }),
      });
      var data = await res.json();

      if (data.success) {
        document.getElementById('utr-form-area').style.display = 'none';
        document.getElementById('utr-success-area').style.display = 'block';
        msg.style.display = 'none';
      } else {
        msg.style.display = 'block';
        msg.className = 'message error';
        msg.textContent = data.message || 'Submission failed. Please try again.';
        btn.disabled = false;
        btn.textContent = 'Submit UTR';
      }
    } catch (err) {
      msg.style.display = 'block';
      msg.className = 'message error';
      msg.textContent = 'Something went wrong. Please try again.';
      btn.disabled = false;
      btn.textContent = 'Submit UTR';
    }
  });
</script>
