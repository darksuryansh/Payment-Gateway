<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Payment Failed' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/checkout.css">
</head>
<body>
  <div class="checkout-container">
    <div class="checkout-card" style="text-align:center; padding-top:36px;">
      <div class="status-icon error-icon">&#10007;</div>
      <h1 class="status-title"><%= typeof title !== 'undefined' ? title : 'Payment Failed' %></h1>
      <p class="status-message"><%= typeof message !== 'undefined' ? message : 'Your payment could not be processed. Please try again.' %></p>
      <div class="footer">
        <p>Secured by <strong>Node Gateway</strong></p>
      </div>
    </div>
  </div>
</body>
</html>
