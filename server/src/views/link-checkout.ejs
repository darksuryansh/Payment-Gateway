<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= link.title || 'Payment' %> - <%= merchant.business_name %></title>
  <link rel="stylesheet" href="/static/css/checkout.css">
  <style>
    :root { --theme-color: #3B82F6; }
  </style>
</head>
<body>
  <div class="checkout-container">
    <div class="checkout-card">
      <div class="merchant-header">
        <% if (merchant.logo_url) { %>
          <img src="<%= merchant.logo_url %>" alt="<%= merchant.business_name %>" class="merchant-logo">
        <% } %>
        <h1 class="merchant-name"><%= merchant.business_name %></h1>
      </div>

      <div class="payment-info">
        <h2 class="payment-title"><%= link.title || link.description || 'Payment' %></h2>
        <% if (link.description && link.title) { %>
          <p class="payment-description"><%= link.description %></p>
        <% } %>

        <% if (link.amount && !link.is_partial) { %>
          <div class="amount-display">
            <span class="currency">&#8377;</span>
            <span class="amount"><%= parseFloat(link.amount).toFixed(2) %></span>
          </div>
        <% } %>

        <% if (link.customer_name) { %>
          <p style="text-align:center; color:#6b7280; font-size:0.875rem; margin-top:0.5rem;">
            For: <strong><%= link.customer_name %></strong>
            <% if (link.customer_email) { %> (<%= link.customer_email %>)<% } %>
          </p>
        <% } %>
      </div>

      <form id="paymentForm" class="payment-form">
        <% if (!link.amount || link.is_partial) { %>
          <div class="form-group">
            <label for="amount">
              Enter Amount (INR)<% if (link.is_partial && link.min_amount) { %> — Min: &#8377;<%= link.min_amount %><% } %>
            </label>
            <input type="number" id="amount" name="amount" min="<%= link.min_amount || 1 %>"
              step="0.01" required placeholder="0.00"
              <% if (link.amount) { %>value="<%= link.amount %>"<% } %>>
          </div>
        <% } %>

        <button type="submit" id="payBtn" class="pay-button">
          Pay<% if (link.amount && !link.is_partial) { %> &#8377;<%= parseFloat(link.amount).toFixed(2) %><% } %>
        </button>
      </form>

      <div id="message" class="message" style="display:none;"></div>

      <% if (link.expires_at) { %>
        <p style="text-align:center; color:#9ca3af; font-size:0.75rem; margin-top:1rem;">
          Expires: <%= new Date(link.expires_at).toLocaleString('en-IN') %>
        </p>
      <% } %>

      <div class="footer">
        <p>Secured by <strong>Boomlex Payment Gateway</strong> &bull; Zero UPI Fees</p>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('paymentForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('payBtn');
      const msg = document.getElementById('message');
      btn.disabled = true;
      btn.textContent = 'Processing...';

      try {
        const body = {};
        const amountInput = document.getElementById('amount');
        if (amountInput) body.amount = parseFloat(amountInput.value);

        const res = await fetch('/pay/link/<%= link.short_url %>/initiate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });

        const data = await res.json();

        if (data.success && data.data?.gateway_url && data.data?.gateway_payload) {
          // Create a hidden form and POST directly to BharatEasy
          const form = document.createElement('form');
          form.method = 'POST';
          form.action = data.data.gateway_url;
          for (const [key, value] of Object.entries(data.data.gateway_payload)) {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = key;
            input.value = value;
            form.appendChild(input);
          }
          document.body.appendChild(form);
          form.submit();
          return;
        } else if (!data.success) {
          msg.style.display = 'block';
          msg.className = 'message error';
          msg.textContent = data.message || 'Payment failed. Please try again.';
          btn.disabled = false;
          btn.textContent = 'Pay';
        }
      } catch (err) {
        msg.style.display = 'block';
        msg.className = 'message error';
        msg.textContent = 'Something went wrong. Please try again.';
        btn.disabled = false;
        btn.textContent = 'Pay';
      }
    });
  </script>
</body>
</html>
