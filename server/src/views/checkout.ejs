<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= page.title %> - Payment</title>
  <link rel="stylesheet" href="/static/css/checkout.css">
  <style>
    :root { --theme-color: <%= page.theme_color || '#000000' %>; }
  </style>
</head>
<body>
  <div class="checkout-container">
    <div class="checkout-card">
      <div class="merchant-header">
        <% if (page.logo_url || merchant.logo_url) { %>
          <img src="<%= page.logo_url || merchant.logo_url %>" alt="<%= merchant.business_name %>" class="merchant-logo">
        <% } %>
        <h1 class="merchant-name"><%= merchant.business_name %></h1>
      </div>

      <div class="payment-info">
        <h2 class="payment-title"><%= page.title %></h2>
        <% if (page.description) { %>
          <p class="payment-description"><%= page.description %></p>
        <% } %>

        <% if (page.amount) { %>
          <div class="amount-display">
            <span class="currency">&#8377;</span>
            <span class="amount"><%= parseFloat(page.amount).toFixed(2) %></span>
          </div>
        <% } %>
      </div>

      <form id="paymentForm" class="payment-form">
        <% if (!page.amount) { %>
          <div class="form-group">
            <label for="amount">Enter Amount (INR)</label>
            <input type="number" id="amount" name="amount" min="1" step="0.01" required placeholder="0.00">
          </div>
        <% } %>

        <div class="form-group">
          <label for="name">Your Name</label>
          <input type="text" id="name" name="name" placeholder="Enter your name">
        </div>

        <div class="form-group">
          <label for="email">Email (optional)</label>
          <input type="email" id="email" name="email" placeholder="your@email.com">
        </div>

        <button type="submit" id="payBtn" class="pay-button">
          Pay <% if (page.amount) { %>&#8377;<%= parseFloat(page.amount).toFixed(2) %><% } %>
        </button>
      </form>

      <div id="message" class="message" style="display:none;"></div>

      <div class="footer">
        <p>Secured by <strong>Boomlex Payment Gateway</strong></p>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('paymentForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('payBtn');
      const msg = document.getElementById('message');
      btn.disabled = true;
      btn.textContent = 'Processing...';

      try {
        const body = {};
        const amountInput = document.getElementById('amount');
        if (amountInput) body.amount = parseFloat(amountInput.value);

        const res = await fetch('<%= baseUrl %>/pay/<%= page.slug %>/initiate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });

        const data = await res.json();

        if (data.success && data.data?.payment_url) {
          window.location.href = data.data.payment_url;
        } else if (data.success) {
          msg.style.display = 'block';
          msg.className = 'message success';
          msg.textContent = 'Payment initiated. Please complete the payment in your UPI app.';
        } else {
          msg.style.display = 'block';
          msg.className = 'message error';
          msg.textContent = data.message || 'Payment failed. Please try again.';
          btn.disabled = false;
          btn.textContent = 'Pay';
        }
      } catch (err) {
        msg.style.display = 'block';
        msg.className = 'message error';
        msg.textContent = 'Something went wrong. Please try again.';
        btn.disabled = false;
        btn.textContent = 'Pay';
      }
    });
  </script>
</body>
</html>
