<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Payment Successful</title>
  <link rel="stylesheet" href="/static/css/checkout.css">
</head>
<body>
  <div class="checkout-container">
    <div class="checkout-card">
      <div class="status-icon success-icon">&#10003;</div>
      <h1 class="status-title">Payment Successful</h1>
      <p class="status-message"><%= typeof message !== 'undefined' ? message : 'Your payment has been processed successfully.' %></p>
      <% if (typeof order_id !== 'undefined') { %>
        <p class="order-ref">Order ID: <strong><%= order_id %></strong></p>
      <% } %>
      <div class="footer">
        <p>Secured by <strong>Boomlex Payment Gateway</strong></p>
      </div>
    </div>
  </div>
</body>
</html>
